# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Environment
.env
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/

# Streamlit
.streamlit/secrets.toml

# Data is reproducible from `make train`; raw + intermediate are gitignored.
data/raw/*
data/interim/*
data/processed/*

# Trained model files (.joblib) are large and not used by the dashboard;
# they are reproducible via `make train`.
artifacts/models/*

# Demo artifacts (metrics JSON, figures PNG, comparison tables, HTML report)
# ARE committed so the dashboard works on first launch without training.
# These are intentionally NOT gitignored.

# Preserve directory structure
!**/.gitkeep
