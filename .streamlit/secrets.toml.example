# Streamlit Cloud secrets template.
#
# Copy this file to `.streamlit/secrets.toml` (gitignored) when deploying
# locally, or paste these key/value pairs into the Streamlit Community Cloud
# "Secrets" panel for the app.
#
# The dashboard runs without any secrets today (Open-Meteo is keyless).
# Future API integrations should land here.

# Example: pre-populate the Live Weather tab with a default city.
# default_city = "London"
